# Makefile for the soccerv3 Python controller.
#
# Builds the soccerv3_native pybind11 extension that wraps the ROBOTIS-OP2
# managers (Gait/Motion/Vision). Webots then launches soccerv3.py which
# imports the locally-built native module.
#
# Usage:
#   make            # creates .venv, installs deps, builds the extension
#   make clean      # removes build artifacts and the .so/.dylib
#   make distclean  # also removes the virtualenv

null :=
space := $(null) $(null)

# Default WEBOTS_HOME per platform if not exported.
ifeq ($(OS),Windows_NT)
  WEBOTS_HOME ?= C:/Program Files/Webots
else
  UNAME_S := $(shell uname -s)
  ifeq ($(UNAME_S),Darwin)
    WEBOTS_HOME ?= /Applications/Webots.app
  else
    WEBOTS_HOME ?= /usr/local/webots
  endif
endif
export WEBOTS_HOME

VENV_DIR  := .venv
PYTHON    ?= python3
VENV_PY   := $(VENV_DIR)/bin/python
VENV_PY3  := $(VENV_DIR)/bin/python3
VENV_PIP  := $(VENV_DIR)/bin/pip

# Absolute path to this Makefile's directory — used to bake runtime.ini.
HERE := $(abspath $(dir $(lastword $(MAKEFILE_LIST))))

# Find the produced extension regardless of CPython tag suffix.
EXT_PATTERN := soccerv3_native*.so

.PHONY: all build clean distclean check runtime-ini

all: build runtime-ini

$(VENV_DIR):
	$(PYTHON) -m venv $(VENV_DIR)
	$(VENV_PIP) install --upgrade pip
	$(VENV_PIP) install -r requirements.txt

build: $(VENV_DIR)
	$(VENV_PY) setup.py build_ext --inplace

# Generate runtime.ini with the ABSOLUTE path to the venv's python3.
# Webots does not reliably resolve relative paths in the [python] COMMAND.
runtime-ini: $(VENV_DIR)
	@printf '; Generated by Makefile — do not edit manually.\n' > runtime.ini
	@printf '; Webots needs the absolute path to the venv interpreter; relative paths\n' >> runtime.ini
	@printf '; in [python] COMMAND are not resolved against the controller directory.\n\n' >> runtime.ini
	@printf '[python]\n' >> runtime.ini
	@printf 'COMMAND = %s\n\n' "$(HERE)/$(VENV_PY3)" >> runtime.ini
	@printf '[environment variables for Linux]\n' >> runtime.ini
	@printf 'WEBOTS_LIBRARY_PATH = $$(WEBOTS_HOME)/resources/projects/libraries/qt_utils:$$(WEBOTS_HOME)/lib/webots\n' >> runtime.ini
	@printf '[environment variables for macOS]\n' >> runtime.ini
	@printf 'WEBOTS_LIBRARY_PATH = $$(WEBOTS_HOME)/Contents/Resources/projects/libraries/qt_utils:$$(WEBOTS_HOME)/Contents/lib/webots\n' >> runtime.ini
	@printf '[environment variables for Windows]\n' >> runtime.ini
	@printf 'WEBOTS_LIBRARY_PATH = "$$(WEBOTS_HOME)\\resources\\projects\\libraries\\qt_utils;$$(WEBOTS_HOME)\\msys64\\mingw64\\bin"\n' >> runtime.ini
	@echo "runtime.ini written with COMMAND = $(HERE)/$(VENV_PY3)"

check: build
	$(VENV_PY) check.py

clean:
	rm -rf build
	rm -f $(EXT_PATTERN)

distclean: clean
	rm -rf $(VENV_DIR)
