+# =============================================================================
+# MIT License
+# Copyright (c) 2026 Aparavi Software AG
+# =============================================================================
+"""Unit tests for `flow.llm.IInstance.checkCondition`.
+
+The LLM flow delegates the routing decision to a wired LLM via the
+control plane. We stub the engine instance so each test injects a
+canned LLM response, then verify the YES/NO parsing and fail-closed
+behavior.
+"""
+
+from __future__ import annotations
+
+from typing import List, Optional
+
+import pytest
+
+from nodes.flow_llm.IInstance import IInstance
+
+
+class _FakeAnswer:
+    def __init__(self, text: str):
+        self._text = text
+
+    def getText(self) -> str:
+        return self._text
+
+
+class _FakeEngineInstance:
+    """Minimal stub that records invoke calls and returns a canned answer."""
+
+    def __init__(
+        self,
+        llm_node_ids: Optional[List[str]] = None,
+        answer_text: str = 'YES',
+        raise_on_invoke: Optional[Exception] = None,
+    ):
+        self._llm_node_ids = llm_node_ids if llm_node_ids is not None else ['llm_1']
+        self._answer_text = answer_text
+        self._raise_on_invoke = raise_on_invoke
+        self.invoke_calls: List[dict] = []
+
+    def getControllerNodeIds(self, classType: str) -> List[str]:
+        if classType == 'llm':
+            return list(self._llm_node_ids)
+        return []
+
+    def invoke(self, param, component_id: str = '') -> None:
+        self.invoke_calls.append({'param': param, 'component_id': component_id})
+        if self._raise_on_invoke is not None:
+            raise self._raise_on_invoke
+        param.answer = _FakeAnswer(self._answer_text)
+
+
+def _build(engine_instance: _FakeEngineInstance) -> IInstance:
+    inst = IInstance.__new__(IInstance)
+    inst.IGlobal = None
+    inst.instance = engine_instance
+    return inst
+
+
+class TestYesNoParsing:
+    @pytest.mark.parametrize(
+        'answer_text, expected',
+        [
+            ('YES', True),
+            ('Yes', True),
+            ('yes', True),
+            ('YES.', True),
+            ('Yes!', True),
+            ('  yes  ', True),
+            ('"YES"', True),
+            ('Yes, definitely', True),
+            ('NO', False),
+            ('No', False),
+            ('Nope', False),
+            ('Unknown', False),
+            ('', False),
+            ('I cannot answer this question', False),
+        ],
+    )
+    def test_parse(self, answer_text, expected):
+        inst = _build(_FakeEngineInstance(answer_text=answer_text))
+        assert inst.checkCondition('Is there a dog?', text='hi') is expected
+
+
+class TestFailClosed:
+    def test_no_llm_wired(self):
+        inst = _build(_FakeEngineInstance(llm_node_ids=[]))
+        assert inst.checkCondition('Is there a dog?', text='hi') is False
+
+    def test_multiple_llms_wired(self):
+        inst = _build(_FakeEngineInstance(llm_node_ids=['llm_1', 'llm_2']))
+        assert inst.checkCondition('Is there a dog?', text='hi') is False
+
+    def test_invoke_raises(self):
+        inst = _build(_FakeEngineInstance(raise_on_invoke=RuntimeError('rate limit')))
+        assert inst.checkCondition('Is there a dog?', text='hi') is False
+
+    def test_empty_question(self):
+        inst = _build(_FakeEngineInstance())
+        assert inst.checkCondition('') is False
+
+    def test_whitespace_question(self):
+        inst = _build(_FakeEngineInstance())
+        assert inst.checkCondition('   ') is False
+
+
+class TestPayloadShaping:
+    def test_text_chunk_inline(self):
+        engine = _FakeEngineInstance(answer_text='YES')
+        inst = _build(engine)
+        inst.checkCondition('Is this Spanish?', text='hola mundo')
+        assert engine.invoke_calls, 'invoke should have been called'
+        question = engine.invoke_calls[0]['param'].question
+        assert 'hola mundo' in question.context
+
+    def test_image_chunk_as_data_url(self):
+        engine = _FakeEngineInstance(answer_text='YES')
+        inst = _build(engine)
+        inst.checkCondition(
+            'Is there a dog?',
+            image=b'\x89PNGfake',
+            mimeType='image/png',
+        )
+        question = engine.invoke_calls[0]['param'].question
+        data_urls = [c for c in question.context if isinstance(c, str) and c.startswith('data:image/png;base64,')]
+        assert data_urls, f'expected an image data URL in contexts, got {question.context!r}'
+
+    def test_streaming_metadata_skipped(self):
+        """`mimeType` and `action` are streaming metadata, not content —
+        they should not appear as standalone context entries.
+        """
+        engine = _FakeEngineInstance(answer_text='NO')
+        inst = _build(engine)
+        inst.checkCondition(
+            'Is this PNG?',
+            image=b'\x89PNGfake',
+            mimeType='image/png',
+            action=2,  # END
+        )
+        question = engine.invoke_calls[0]['param'].question
+        # mimeType should NOT appear as a raw context line.
+        for c in question.context:
+            assert c != 'image/png', 'mimeType should not be a context entry on its own'
+            # action also shouldn't appear standalone.
+            assert c != '2'
diff --git a/nodes/test/flow/test_pyeval_check_condition.py b/nodes/test/flow/test_pyeval_check_condition.py
new file mode 100644
index 00000000..b7b22de5
--- /dev/null
+++ b/nodes/test/flow/test_pyeval_check_condition.py
@@ -0,0 +1,151 @@
+# =============================================================================
+# MIT License
+# Copyright (c) 2026 Aparavi Software AG
+# =============================================================================
+"""Unit tests for `flow.pyeval.IInstance.checkCondition`.
+
+The pyeval flow's job is to safely evaluate a Python expression against
+the active lane payload + the current entry. These tests exercise the
+sandbox boundary and the fail-closed behaviour without needing the
+engine runtime.
+"""
+
+from __future__ import annotations
+
+import pytest
+
+from nodes.flow_pyeval.IInstance import IInstance
+
+
+def _build():
+    """Construct a bare IInstance with no engine context."""
+    inst = IInstance.__new__(IInstance)
+    inst.IGlobal = None
+    inst.instance = None
+    return inst
+
+
+class TestBasicEvaluation:
+    def test_literal_true(self):
+        inst = _build()
+        assert inst.checkCondition('True') is True
+
+    def test_literal_false(self):
+        inst = _build()
+        assert inst.checkCondition('False') is False
+
+    def test_arithmetic(self):
+        inst = _build()
+        assert inst.checkCondition('1 + 2 == 3') is True
+
+    def test_lane_binding(self):
+        inst = _build()
+        assert inst.checkCondition("'foo' in text", text='hello foo bar') is True
+        assert inst.checkCondition("'baz' in text", text='hello foo bar') is False
+
+    def test_byte_level_image_check(self):
+        inst = _build()
+        assert (
+            inst.checkCondition(
+                "image[:4] == b'\\x89PNG'",
+                image=b'\x89PNG\r\n\x1a\nrest',
+            )
+            is True
+        )
+        assert (
+            inst.checkCondition(
+                "image[:4] == b'\\x89PNG'",
+                image=b'\xff\xd8\xff\xe0jpeg',
+            )
+            is False
+        )
+
+    def test_len_on_bytes(self):
+        inst = _build()
+        assert inst.checkCondition('len(image) > 100', image=b'x' * 200) is True
+        assert inst.checkCondition('len(image) > 100', image=b'x' * 50) is False
+
+    def test_or_across_lanes_no_nameerror(self):
+        """Each evaluation only binds the lanes the call provides; a
+        condition that references an unbound lane should fail-closed
+        rather than crash. Best practice is to bind defaults — but the
+        sandbox should at minimum not propagate.
+        """
+        inst = _build()
+        # `text` is bound, `table` is not — `table` reference should
+        # return False (fail-closed) without raising.
+        assert inst.checkCondition("'foo' in table", text='foo') is False
+
+
+class TestSandboxRejections:
+    @pytest.mark.parametrize(
+        'expr',
+        [
+            'import os',
+            '__import__("os")',
+            'x.__class__',
+            'x._private',
+            'eval("1")',
+            'exec("x=1")',
+        ],
+    )
+    def test_rejects_dangerous_constructs(self, expr):
+        inst = _build()
+        # All of these should fail-closed (return False) rather than crash.
+        assert inst.checkCondition(expr, x=1) is False
+
+    def test_empty_condition(self):
+        inst = _build()
+        assert inst.checkCondition('') is False
+
+    def test_whitespace_only(self):
+        inst = _build()
+        assert inst.checkCondition('   ') is False
+
+    def test_syntax_error(self):
+        inst = _build()
+        assert inst.checkCondition('1 +') is False
+
+    def test_runtime_error(self):
+        inst = _build()
+        assert inst.checkCondition('1 / 0') is False
+
+    def test_leading_whitespace_is_stripped(self):
+        """`ast.parse(mode='eval')` rejects leading whitespace as
+        indentation; the driver must strip before parsing so accidental
+        copy-paste spaces don't break valid expressions.
+        """
+        inst = _build()
+        assert inst.checkCondition('  True  ') is True
+
+
+class TestSafeBuiltins:
+    def test_len_available(self):
+        inst = _build()
+        assert inst.checkCondition('len("abc") == 3') is True
+
+    def test_int_from_bytes_for_png_dimensions(self):
+        """`int.from_bytes` is reachable for byte-level PNG header parsing."""
+        inst = _build()
+        # PNG width is at bytes 16-19 (big-endian uint32). 0x00000064 = 100.
+        png_bytes = (
+            b'\x89PNG\r\n\x1a\n'  # 8-byte signature
+            + b'\x00\x00\x00\x0d'  # IHDR chunk length
+            + b'IHDR'  # chunk type
+            + b'\x00\x00\x00\x64'  # width = 100
+            + b'\x00\x00\x00\x32'  # height = 50
+            + b'\x08\x02\x00\x00\x00'  # bit depth + color + ...
+        )
+        assert (
+            inst.checkCondition(
+                "int.from_bytes(image[16:20], 'big') == 100",
+                image=png_bytes,
+            )
+            is True
+        )
+
+    def test_dangerous_builtin_absent(self):
+        inst = _build()
+        # `eval` is not in the safe builtins, so calling it raises
+        # NameError → caught → fail-closed.
+        assert inst.checkCondition('eval("1")') is False
