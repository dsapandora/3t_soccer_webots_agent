@@ -0,0 +1,125 @@
+# =============================================================================
+# MIT License
+# Copyright (c) 2026 Aparavi Software AG
+# =============================================================================
+"""Test setup for flow_* unit tests.
+
+Adds `nodes/src` to `sys.path` and stubs the engine modules
+(`rocketlib`, `ai.common.config`, `ai.common.schema`) so the new
+`flow.base` / `flow.pyeval` / `flow.llm` packages are importable
+without the engine runtime.
+"""
+
+from __future__ import annotations
+
+import sys
+import types
+from pathlib import Path
+
+_NODES_SRC = Path(__file__).resolve().parent.parent.parent / 'src'
+if str(_NODES_SRC) not in sys.path:
+    sys.path.insert(0, str(_NODES_SRC))
+
+
+def _install_depends_stub() -> None:
+    if 'depends' in sys.modules:
+        return
+    stub = types.ModuleType('depends')
+    stub.depends = lambda *_args, **_kwargs: None
+    sys.modules['depends'] = stub
+
+
+def _install_rocketlib_stub() -> None:
+    if 'rocketlib' in sys.modules:
+        return
+
+    rocketlib = types.ModuleType('rocketlib')
+
+    class _IInstanceBase:
+        IGlobal = None
+        IEndpoint = None
+        instance = None
+
+        def preventDefault(self):
+            raise _PreventDefault()
+
+    class _IGlobalBase:
+        IEndpoint = None
+        glb = None
+
+    class _OpenMode:
+        CONFIG = 'CONFIG'
+        RUN = 'RUN'
+
+    class _AviAction:
+        BEGIN = 0
+        WRITE = 1
+        END = 2
+
+    class _PreventDefault(Exception):
+        pass
+
+    rocketlib.IInstanceBase = _IInstanceBase
+    rocketlib.IGlobalBase = _IGlobalBase
+    rocketlib.OPEN_MODE = _OpenMode
+    rocketlib.AVI_ACTION = _AviAction
+    sys.modules['rocketlib'] = rocketlib
+
+    # rocketlib.types
+    rl_types = types.ModuleType('rocketlib.types')
+
+    class _IInvokeLLM:
+        class Ask:
+            def __init__(self, question):
+                self.question = question
+                self.answer = None  # tests populate this
+
+    rl_types.IInvokeLLM = _IInvokeLLM
+    sys.modules['rocketlib.types'] = rl_types
+
+
+def _install_ai_common_stubs() -> None:
+    if 'ai' not in sys.modules:
+        ai = types.ModuleType('ai')
+        ai_common = types.ModuleType('ai.common')
+        ai_common_config = types.ModuleType('ai.common.config')
+        ai_common_schema = types.ModuleType('ai.common.schema')
+
+        class _Config:
+            @staticmethod
+            def getNodeConfig(*_args, **_kwargs) -> dict:
+                return {}
+
+        class _Question:
+            def __init__(self):
+                self.context = []
+                self.questions = []
+
+            def addContext(self, value):
+                self.context.append(value)
+
+            def addQuestion(self, value):
+                self.questions.append(value)
+
+        class _Answer:
+            def __init__(self, text=''):
+                self._text = text
+
+            def getText(self):
+                return self._text
+
+        ai_common_config.Config = _Config
+        ai_common_schema.Question = _Question
+        ai_common_schema.Answer = _Answer
+        ai.common = ai_common
+        ai_common.config = ai_common_config
+        ai_common.schema = ai_common_schema
+        sys.modules['ai'] = ai
+        sys.modules['ai.common'] = ai_common
+        sys.modules['ai.common.config'] = ai_common_config
+        sys.modules['ai.common.schema'] = ai_common_schema
+
+
+_install_depends_stub()
+_install_rocketlib_stub()
+_install_ai_common_stubs()
