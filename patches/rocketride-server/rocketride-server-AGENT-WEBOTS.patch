+# =============================================================================
+# Soccer robot tactical tool — ATTACK_GOAL.
+#
+# Invoked by the tactician agent. Validates the side parameter and returns a
+# structured action plan that the Webots controller's FSM consumes.
+# =============================================================================
+
+"""tool_attack_goal — walk to the ball and kick it toward the enemy goal."""
+
+from __future__ import annotations
+
+from rocketlib import IInstanceBase, tool_function
+
+from .IGlobal import IGlobal
+
+
+_ALLOWED_SIDES = ("left", "right")
+
+
+class IInstance(IInstanceBase):
+    IGlobal: IGlobal
+
+    @tool_function(
+        input_schema={
+            "type": "object",
+            "required": ["side"],
+            "properties": {
+                "side": {
+                    "type": "string",
+                    "enum": list(_ALLOWED_SIDES),
+                    "description": "Which foot kicks the ball — choose so the kicking foot points at the enemy goal.",
+                },
+                "duration_ms": {
+                    "type": "integer",
+                    "minimum": 1000,
+                    "maximum": 8000,
+                    "default": 4000,
+                    "description": "How long this tactical action should run before the agent re-plans.",
+                },
+                "rationale": {
+                    "type": "string",
+                    "default": "",
+                    "description": "One short sentence explaining why this action was chosen.",
+                },
+            },
+        },
+        output_schema={
+            "type": "object",
+            "properties": {
+                "action": {"type": "string"},
+                "params": {"type": "object"},
+                "duration_ms": {"type": "integer"},
+                "rationale": {"type": "string"},
+            },
+        },
+        description=(
+            "Soccer robot tactical action ATTACK_GOAL: walk toward the ball and "
+            "kick it with the selected foot toward the enemy goal."
+        ),
+    )
+    def execute(self, args):
+        if not isinstance(args, dict):
+            raise ValueError("Tool input must be a JSON object (dict)")
+        side = args.get("side")
+        if side not in _ALLOWED_SIDES:
+            raise ValueError(f"'side' must be one of {_ALLOWED_SIDES}, got {side!r}")
+        duration_ms = int(args.get("duration_ms", 4000))
+        rationale = str(args.get("rationale", ""))
+        return {
+            "action": "ATTACK_GOAL",
+            "params": {"side": side},
+            "duration_ms": duration_ms,
+            "rationale": rationale,
+        }
