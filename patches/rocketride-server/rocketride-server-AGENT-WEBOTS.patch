+# =============================================================================
+# RocketRide Engine
+# =============================================================================
+# MIT License
+# Copyright (c) 2026 Aparavi Software AG
+# =============================================================================
+
+"""OpenAI Files Upload - shared client and config."""
+
+from __future__ import annotations
+
+from ai.common.config import Config
+from rocketlib import IGlobalBase, OPEN_MODE, warning
+
+from openai import OpenAI
+
+
+class IGlobal(IGlobalBase):
+    client: OpenAI | None = None
+    purpose: str = 'vision'
+
+    def beginGlobal(self) -> None:
+        if self.IEndpoint.endpoint.openMode == OPEN_MODE.CONFIG:
+            return
+
+        cfg = Config.getNodeConfig(self.glb.logicalType, self.glb.connConfig)
+        apikey = str((cfg.get('apikey') or '')).strip()
+
+        if not apikey:
+            raise Exception('openai_files_upload: apikey is required')
+
+        self.purpose = str(cfg.get('purpose') or 'vision').strip()
+
+        try:
+            self.client = OpenAI(api_key=apikey)
+        except Exception as e:
+            warning(str(e))
+            raise
+
+    def validateConfig(self) -> None:
+        try:
+            cfg = Config.getNodeConfig(self.glb.logicalType, self.glb.connConfig)
+            apikey = str((cfg.get('apikey') or '')).strip()
+            if not apikey:
+                warning('apikey is required')
+        except Exception as e:
+            warning(str(e))
+
+    def endGlobal(self) -> None:
+        self.client = None
diff --git a/nodes/src/nodes/openai_files_upload/IInstance.py b/nodes/src/nodes/openai_files_upload/IInstance.py
new file mode 100644
index 00000000..2fe53d4f
--- /dev/null
+++ b/nodes/src/nodes/openai_files_upload/IInstance.py
@@ -0,0 +1,205 @@
+# =============================================================================
+# RocketRide Engine
+# =============================================================================
+# MIT License
+# Copyright (c) 2026 Aparavi Software AG
+# =============================================================================
+
+"""OpenAI Files Upload instance.
+
+Two operating modes:
+
+1. Image lane in (raw bytes):
+     Buffers the incoming image, uploads it to the OpenAI Files API and emits
+     the resulting file_id as a single line on the ``text`` lane. Suitable for
+     pipelines where image data already flows through the image lane.
+
+2. Text lane in (JSON object):
+     For each key in the JSON whose name ends in ``_b64`` (single base64
+     image) or ``_b64s`` (array of base64 images), uploads the image(s) to
+     the Files API and rewrites the key to ``_id`` / ``_ids`` with the
+     resulting file_id(s). Other keys are forwarded untouched. Emits the new
+     JSON object on the ``text`` lane.
+
+This makes the node a generic "OpenAI base64 -> file_id" transformer that any
+downstream node can rely on (e.g. ``gpt_image_edit``).
+"""
+
+from __future__ import annotations
+
+import base64
+import io
+import json
+import mimetypes
+
+from rocketlib import AVI_ACTION, IInstanceBase, debug, invoke_function, warning
+
+from .IGlobal import IGlobal
+
+
+_MIME_EXT = {
+    'image/png': 'png',
+    'image/jpeg': 'jpg',
+    'image/webp': 'webp',
+    'image/gif': 'gif',
+}
+
+
+class IInstance(IInstanceBase):
+    IGlobal: IGlobal
+
+    def __init__(self):
+        super().__init__()
+        self.image_data: bytearray | None = None
+
+    # -- mode 1: image lane in -------------------------------------------------
+
+    def writeImage(self, action: int, mimeType: str, buffer: bytes):
+        if action == AVI_ACTION.BEGIN:
+            debug(f'openai_files_upload[image]: BEGIN mime={mimeType}')
+            self.image_data = bytearray()
+            return self.preventDefault()
+
+        if action == AVI_ACTION.WRITE:
+            if self.image_data is None:
+                self.image_data = bytearray()
+            if buffer:
+                self.image_data += buffer
+            return self.preventDefault()
+
+        if action == AVI_ACTION.END:
+            data = bytes(self.image_data) if self.image_data else b''
+            self.image_data = None
+            debug(f'openai_files_upload[image]: END mime={mimeType} bytes={len(data)}')
+
+            if not data:
+                warning('openai_files_upload[image]: empty image buffer; nothing to upload')
+                return self.preventDefault()
+
+            client = self.IGlobal.client
+            if client is None:
+                warning('openai_files_upload[image]: OpenAI client not initialized')
+                return self.preventDefault()
+
+            ext = _MIME_EXT.get((mimeType or '').lower())
+            if ext is None:
+                guessed = mimetypes.guess_extension(mimeType or '') or '.bin'
+                ext = guessed.lstrip('.') or 'bin'
+
+            buf = io.BytesIO(data)
+            buf.name = f'frame.{ext}'
+
+            try:
+                uploaded = client.files.create(file=buf, purpose=self.IGlobal.purpose)
+                debug(f'openai_files_upload[image]: uploaded id={uploaded.id}')
+            except Exception as e:
+                warning(f'openai_files_upload[image]: upload failed: {e!r}')
+                return self.preventDefault()
+
+            self.instance.writeText(uploaded.id)
+            return self.preventDefault()
+
+        return None
+
+    # -- mode 2: text lane in (JSON) ------------------------------------------
+
+    def writeText(self, text: str):
+        client = self.IGlobal.client
+        if client is None:
+            warning('openai_files_upload[json]: OpenAI client not initialized')
+            return self.preventDefault()
+
+        body = (text or '').strip()
+        if not body:
+            warning('openai_files_upload[json]: empty record')
+            return self.preventDefault()
+
+        try:
+            payload = json.loads(body)
+        except (json.JSONDecodeError, TypeError) as e:
+            warning(f'openai_files_upload[json]: record is not valid JSON: {e}')
+            return self.preventDefault()
+
+        if not isinstance(payload, dict):
+            warning('openai_files_upload[json]: payload must be a JSON object')
+            return self.preventDefault()
+
+        debug(f'openai_files_upload[json]: input keys={list(payload.keys())}')
+
+        out: dict = {}
+        try:
+            for key, value in payload.items():
+                if key.endswith('_b64s') and isinstance(value, list):
+                    new_key = key[:-len('_b64s')] + '_ids'
+                    file_ids = []
+                    for i, b64 in enumerate(value):
+                        if not isinstance(b64, str) or not b64:
+                            raise ValueError(f'{key}[{i}] is not a non-empty base64 string')
+                        file_ids.append(self._upload_b64(client, b64, name=f'{key}_{i}.png'))
+                    out[new_key] = file_ids
+                    debug(f'openai_files_upload[json]: {key} ({len(value)}) -> {new_key} ({len(file_ids)})')
+                elif key.endswith('_b64') and isinstance(value, str):
+                    new_key = key[:-len('_b64')] + '_id'
+                    out[new_key] = self._upload_b64(client, value, name=f'{key}.png')
+                    debug(f'openai_files_upload[json]: {key} -> {new_key}={out[new_key]}')
+                else:
+                    out[key] = value
+        except Exception as e:
+            warning(f'openai_files_upload[json]: upload failed: {e!r}')
+            return self.preventDefault()
+
+        result_json = json.dumps(out)
+        debug(f'openai_files_upload[json]: emitting keys={list(out.keys())}')
+        self.instance.writeText(result_json)
+        return self.preventDefault()
+
+    # -- mode 3: control plane (invoke) ---------------------------------------
+
+    @invoke_function
+    def upload(self, param):
+        """Invoke handler. Receives an IInvokeUploader.Upload op and transforms
+        the payload's _b64 / _b64s keys into _id / _ids using the Files API.
+        """
+        payload = getattr(param, 'payload', None)
+        if not isinstance(payload, dict):
+            warning('openai_files_upload[invoke]: payload must be a dict')
+            return {}
+
+        client = self.IGlobal.client
+        if client is None:
+            warning('openai_files_upload[invoke]: OpenAI client not initialized')
+            return {}
+
+        debug(f'openai_files_upload[invoke]: input keys={list(payload.keys())}')
+
+        out: dict = {}
+        try:
+            for key, value in payload.items():
+                if key.endswith('_b64s') and isinstance(value, list):
+                    new_key = key[:-len('_b64s')] + '_ids'
+                    file_ids = []
+                    for i, b64 in enumerate(value):
+                        if not isinstance(b64, str) or not b64:
+                            raise ValueError(f'{key}[{i}] is not a non-empty base64 string')
+                        file_ids.append(self._upload_b64(client, b64, name=f'{key}_{i}.png'))
+                    out[new_key] = file_ids
+                elif key.endswith('_b64') and isinstance(value, str):
+                    new_key = key[:-len('_b64')] + '_id'
+                    out[new_key] = self._upload_b64(client, value, name=f'{key}.png')
+                else:
+                    out[key] = value
+        except Exception as e:
+            warning(f'openai_files_upload[invoke]: upload failed: {e!r}')
+            raise
+
+        debug(f'openai_files_upload[invoke]: output keys={list(out.keys())}')
+        return out
+
+    # -- helper ----------------------------------------------------------------
+
+    def _upload_b64(self, client, b64: str, *, name: str) -> str:
+        data = base64.b64decode(b64)
+        buf = io.BytesIO(data)
+        buf.name = name
+        uploaded = client.files.create(file=buf, purpose=self.IGlobal.purpose)
+        return uploaded.id
