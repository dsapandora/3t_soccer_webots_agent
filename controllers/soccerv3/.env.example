# Copy to .env and fill in real values.
# .env is gitignored (see ../../.gitignore in projects/webots/).
# Only variables prefixed with ROCKETRIDE_ are substituted into pipeline JSON.

# RocketRide server connection.
# IMPORTANT: this is a WebSocket URI (ws:// for local, wss:// for TLS).
# Examples:
#   ws://localhost:8080            # local rocketride-server in dev
#   wss://cloud.rocketride.ai      # hosted production
ROCKETRIDE_URI=ws://localhost:8080
ROCKETRIDE_APIKEY=replace-with-your-rocketride-apikey

# LLM provider key — referenced as ${ROCKETRIDE_ANTHROPIC_KEY} inside strategy.pipe
ROCKETRIDE_ANTHROPIC_KEY=sk-ant-api03-replace-with-your-anthropic-key
