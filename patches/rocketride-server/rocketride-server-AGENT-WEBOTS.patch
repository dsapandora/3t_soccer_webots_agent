+
+from rocketlib import IInstanceBase, tool_function
+
+from .IGlobal import IGlobal
+
+
+_ALLOWED_SIDES = ("left", "right", "back")
+
+
+class IInstance(IInstanceBase):
+    IGlobal: IGlobal
+
+    @tool_function(
+        input_schema={
+            "type": "object",
+            "required": ["retreat_side"],
+            "properties": {
+                "retreat_side": {
+                    "type": "string",
+                    "enum": list(_ALLOWED_SIDES),
+                    "description": "Which way to retreat — opposite of the line side ('left'/'right'), or straight 'back'.",
+                },
+                "duration_ms": {
+                    "type": "integer", "minimum": 500, "maximum": 5000, "default": 2000,
+                    "description": "How long to retreat before re-planning.",
+                },
+                "rationale": {
+                    "type": "string", "default": "",
+                    "description": "Why we are retreating now.",
+                },
+            },
+        },
+        output_schema={
+            "type": "object",
+            "properties": {
+                "action": {"type": "string"},
+                "params": {"type": "object"},
+                "duration_ms": {"type": "integer"},
+                "rationale": {"type": "string"},
+            },
+        },
+        description=(
+            "Soccer robot reactive action AVOID_LINE: walk backward and turn away "
+            "from a field boundary line."
+        ),
+    )
+    def execute(self, args):
+        if not isinstance(args, dict):
+            raise ValueError("Tool input must be a JSON object (dict)")
+        retreat_side = args.get("retreat_side")
+        if retreat_side not in _ALLOWED_SIDES:
+            raise ValueError(f"'retreat_side' must be one of {_ALLOWED_SIDES}, got {retreat_side!r}")
+        duration_ms = int(args.get("duration_ms", 2000))
+        rationale = str(args.get("rationale", ""))
+        return {
+            "action": "AVOID_LINE",
+            "params": {"retreat_side": retreat_side},
+            "duration_ms": duration_ms,
+            "rationale": rationale,
+        }
