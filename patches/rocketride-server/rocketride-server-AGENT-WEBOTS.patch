+# =============================================================================
+# RocketRide Engine
+# =============================================================================
+# MIT License
+# Copyright (c) 2026 Aparavi Software AG
+# =============================================================================
+
+"""GPT Image Edit - shared client and per-pipeline defaults.
+
+Per-record values (frame_b64, ref_b64s, prompt) arrive on the text lane in a
+JSON payload — they are NOT in this config.
+"""
+
+from __future__ import annotations
+
+from ai.common.config import Config
+from rocketlib import IGlobalBase, OPEN_MODE, warning
+
+from openai import OpenAI
+
+
+class IGlobal(IGlobalBase):
+    client: OpenAI | None = None
+    model: str = 'gpt-5.5'
+    image_model: str = 'gpt-image-2'
+    default_quality: str = 'low'
+    default_size: str = '1024x1024'
+    moderation: str = 'auto'
+
+    def beginGlobal(self) -> None:
+        if self.IEndpoint.endpoint.openMode == OPEN_MODE.CONFIG:
+            return
+
+        cfg = Config.getNodeConfig(self.glb.logicalType, self.glb.connConfig)
+        apikey = str((cfg.get('apikey') or '')).strip()
+
+        if not apikey:
+            raise Exception('gpt_image_edit: apikey is required')
+
+        self.model = str(cfg.get('model') or 'gpt-5.5').strip()
+        self.image_model = str(cfg.get('imageModel') or 'gpt-image-2').strip()
+        self.default_quality = str(cfg.get('quality') or 'low').strip()
+        self.default_size = str(cfg.get('size') or '1024x1024').strip()
+        self.moderation = str(cfg.get('moderation') or 'auto').strip()
+
+        try:
+            self.client = OpenAI(api_key=apikey)
+        except Exception as e:
+            warning(str(e))
+            raise
+
+    def validateConfig(self) -> None:
+        try:
+            cfg = Config.getNodeConfig(self.glb.logicalType, self.glb.connConfig)
+            apikey = str((cfg.get('apikey') or '')).strip()
+            if not apikey:
+                warning('apikey is required')
+        except Exception as e:
+            warning(str(e))
+
+    def endGlobal(self) -> None:
+        self.client = None
diff --git a/nodes/src/nodes/gpt_image_edit/IInstance.py b/nodes/src/nodes/gpt_image_edit/IInstance.py
new file mode 100644
index 00000000..210026bf
--- /dev/null
+++ b/nodes/src/nodes/gpt_image_edit/IInstance.py
@@ -0,0 +1,153 @@
+# =============================================================================
+# RocketRide Engine
+# =============================================================================
+# MIT License
+# Copyright (c) 2026 Aparavi Software AG
+# =============================================================================
+
+"""GPT Image Edit instance.
+
+Receives a JSON record on the text lane. The record can be in either of two
+shapes:
+
+  A) Pre-uploaded mode:
+     {"frame_id": "file-XXX", "ref_ids": ["file-AAA", ...], "prompt": "..."}
+
+  B) Base64 mode (requires an uploader connected via control plane):
+     {"frame_b64": "<base64>", "ref_b64s": ["<base64>", ...], "prompt": "..."}
+
+If the record arrives in shape B, the editor invokes the optional uploader
+resource (declared in services.json as ``invoke: {uploader: {...}}``) to
+transform _b64 / _b64s keys into _id / _ids. If no uploader is connected and
+shape B is received, the record fails with a clear warning.
+
+The Responses API ``image_generation`` tool is then called with the resulting
+file_ids and the edited PNG is emitted on the image lane.
+"""
+
+from __future__ import annotations
+
+import base64
+import json
+
+from rocketlib import AVI_ACTION, IInstanceBase, debug, warning
+
+from .IGlobal import IGlobal
+
+try:
+    from nodes.openai_files_upload.invoke_types import IInvokeUploader
+except Exception:  # pragma: no cover — uploader package optional
+    IInvokeUploader = None  # type: ignore[assignment]
+
+
+class IInstance(IInstanceBase):
+    IGlobal: IGlobal
+
+    def writeText(self, text: str):
+        client = self.IGlobal.client
+        if client is None:
+            warning('gpt_image_edit: OpenAI client not initialized')
+            return self.preventDefault()
+
+        body = (text or '').strip()
+        if not body:
+            warning('gpt_image_edit: empty record')
+            return self.preventDefault()
+
+        try:
+            payload = json.loads(body)
+        except (json.JSONDecodeError, TypeError) as e:
+            warning(f'gpt_image_edit: record is not valid JSON: {e}')
+            return self.preventDefault()
+
+        if not isinstance(payload, dict):
+            warning('gpt_image_edit: payload must be a JSON object')
+            return self.preventDefault()
+
+        # If the record carries base64 keys, ask the connected uploader to
+        # transform them into file_ids first.
+        if any(k.endswith('_b64') or k.endswith('_b64s') for k in payload):
+            if IInvokeUploader is None:
+                warning('gpt_image_edit: record has _b64 keys but IInvokeUploader is not importable')
+                return self.preventDefault()
+            try:
+                debug('gpt_image_edit: record has base64 keys, invoking uploader...')
+                payload = self.instance.invoke(IInvokeUploader.Upload(payload=payload))
+            except Exception as e:
+                warning(f'gpt_image_edit: uploader invoke failed: {e!r}. Connect an openai_files_upload node to gpt_image_edit_1 with control: [{{"classType": "uploader", "from": "<editor_id>"}}], or send file_ids directly.')
+                return self.preventDefault()
+            if not isinstance(payload, dict):
+                warning(f'gpt_image_edit: uploader returned non-dict ({type(payload).__name__})')
+                return self.preventDefault()
+
+        frame_id = payload.get('frame_id')
+        ref_ids = payload.get('ref_ids') or []
+        prompt = payload.get('prompt')
+
+        if not isinstance(frame_id, str) or not frame_id:
+            warning('gpt_image_edit: missing/invalid frame_id after upload step')
+            return self.preventDefault()
+        if not isinstance(ref_ids, list) or not ref_ids or not all(isinstance(r, str) and r for r in ref_ids):
+            warning('gpt_image_edit: ref_ids must be a non-empty list of file_id strings')
+            return self.preventDefault()
+        if len(ref_ids) > 4:
+            warning('gpt_image_edit: at most 4 reference images supported; truncating')
+            ref_ids = ref_ids[:4]
+        if not isinstance(prompt, str) or not prompt:
+            warning('gpt_image_edit: missing/invalid prompt')
+            return self.preventDefault()
+
+        quality = (payload.get('quality') or self.IGlobal.default_quality or 'low').strip()
+        size = (payload.get('size') or self.IGlobal.default_size or '1024x1024').strip()
+
+        debug(f'gpt_image_edit: editing frame_id={frame_id} refs={len(ref_ids)} quality={quality} size={size} model={self.IGlobal.model}')
+
+        content = [{'type': 'input_text', 'text': prompt}]
+        content.append({'type': 'input_image', 'file_id': frame_id})
+        for rid in ref_ids:
+            content.append({'type': 'input_image', 'file_id': rid})
+
+        image_tool = {
+            'type': 'image_generation',
+            'quality': quality,
+            'moderation': self.IGlobal.moderation,
+        }
+        if self.IGlobal.image_model:
+            image_tool['model'] = self.IGlobal.image_model
+        if size and size != 'auto':
+            image_tool['size'] = size
+
+        try:
+            response = client.responses.create(
+                model=self.IGlobal.model,
+                input=[{'role': 'user', 'content': content}],
+                tools=[image_tool],
+            )
+            debug(f'gpt_image_edit: responses.create returned id={getattr(response, "id", "?")}')
+        except Exception as e:
+            warning(f'gpt_image_edit: responses.create failed: {e!r}')
+            return self.preventDefault()
+
+        results = [
+            output.result
+            for output in getattr(response, 'output', []) or []
+            if getattr(output, 'type', None) == 'image_generation_call' and getattr(output, 'result', None)
+        ]
+        if not results:
+            warning('gpt_image_edit: no image_generation_call result in response')
+            return self.preventDefault()
+
+        try:
+            png_bytes = base64.b64decode(results[0])
+        except Exception as e:
+            warning(f'gpt_image_edit: failed to decode base64 result: {e!r}')
+            return self.preventDefault()
+
+        mime = 'image/png'
+        debug(f'gpt_image_edit: emitting image bytes={len(png_bytes)}')
+        self.instance.writeImage(AVI_ACTION.BEGIN, mime)
+        self.instance.writeImage(AVI_ACTION.WRITE, mime, png_bytes)
+        self.instance.writeImage(AVI_ACTION.END, mime)
+        debug('gpt_image_edit: emit complete')
+
+        return self.preventDefault()
