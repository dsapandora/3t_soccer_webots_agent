+"""tool_walk — atomic walk-forward skill (test node)."""
+
+from __future__ import annotations
+
+from rocketlib import IInstanceBase, tool_function
+
+from .IGlobal import IGlobal
+
+
+class IInstance(IInstanceBase):
+    IGlobal: IGlobal
+
+    @tool_function(
+        input_schema={
+            "type": "object",
+            "properties": {
+                "rationale": {
+                    "type": "string", "default": "",
+                    "description": "Why we are walking.",
+                },
+            },
+        },
+        output_schema={
+            "type": "object",
+            "properties": {
+                "action": {"type": "string"},
+                "params": {"type": "object"},
+                "duration_ms": {"type": "integer"},
+                "rationale": {"type": "string"},
+            },
+        },
+        description=(
+            "Soccer robot atomic skill WALK: walk forward for 2 seconds. "
+            "Always call this tool every turn."
+        ),
+    )
+    def execute(self, args):
+        # Audit log so we can verify the node actually runs.
+        try:
+            import json
+            import os
+            import time
+            with open("/tmp/rocketride_tool_walk.log", "a", encoding="utf-8") as f:
+                f.write(json.dumps({
+                    "t": time.strftime("%H:%M:%S"),
+                    "pid": os.getpid(),
+                    "args": args,
+                }) + "\n")
+        except Exception:
+            pass
+        rationale = ""
+        if isinstance(args, dict):
+            rationale = str(args.get("rationale", ""))
+        return {
+            "action": "WALK",
+            "params": {},
+            "duration_ms": 2000,
+            "rationale": rationale,
+        }
