+"""tool_walk_arc_right — atomic skill emitting action WALK_ARC_RIGHT."""
+
+from __future__ import annotations
+
+from rocketlib import IInstanceBase, tool_function
+
+from .IGlobal import IGlobal
+
+
+class IInstance(IInstanceBase):
+    IGlobal: IGlobal
+
+    @tool_function(
+        input_schema={"type": "object", "properties": {"duration_ms": {"type": "integer", "default": 2500, "description": "How long this action runs (ms)."}, "rationale": {"type": "string", "default": "", "description": "One short sentence reason."}}},
+        output_schema={"type": "object",
+                       "properties": {"action": {"type": "string"},
+                                      "params": {"type": "object"},
+                                      "duration_ms": {"type": "integer"},
+                                      "rationale": {"type": "string"}}},
+        description="Soccer robot atomic skill WALK_ARC_RIGHT: Walk forward while curving RIGHT.",
+    )
+    def execute(self, args):
+        try:
+            import json as _j, time as _t
+            with open('/tmp/rocketride_debug.log', 'a') as _f:
+                _f.write(_j.dumps({'t': _t.strftime('%H:%M:%S.%f')[:-3],
+                    'src': 'tool_walk_arc_right', 'event': 'execute', 'args': args},
+                    default=str) + '\n')
+        except Exception:
+            pass
+
+        params = {}
+        if not isinstance(args, dict):
+            args = {}
+        duration_ms = int(args.get("duration_ms", 2500))
+        rationale = str(args.get("rationale", ""))
+        return {"action": "WALK_ARC_RIGHT", "params": params,
+                "duration_ms": duration_ms, "rationale": rationale}
