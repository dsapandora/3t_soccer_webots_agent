+# =============================================================================
+# RocketRide Engine
+# =============================================================================
+# MIT License
+# Copyright (c) 2026 Aparavi Software AG
+# =============================================================================
+
+"""Invoke type for openai_files_upload acting as a control-plane resource.
+
+A consumer (e.g. gpt_image_edit) declares ``invoke: {uploader: {min: 0, max: 1}}``
+in its services.json and calls::
+
+    result = self.instance.invoke(IInvokeUploader.Upload(payload={...}))
+
+The resolver routes the call to the instance of openai_files_upload that
+declares ``control: [{classType: "uploader", from: "<consumer_id>"}]``.
+
+The lane name ``"uploader"`` is the contract — both sides must agree.
+"""
+
+from __future__ import annotations
+
+from typing import Any
+
+from pydantic import Field
+
+from rocketlib import IInvoke, IInvokeOp
+
+
+class IInvokeUploader(IInvoke):
+    """Uploader namespace — construct via inner classes."""
+
+    class Upload(IInvokeOp):
+        """Transform a JSON object: ``*_b64`` -> ``*_id``, ``*_b64s`` -> ``*_ids``.
+
+        ``payload`` is the input JSON object (dict). The handler returns a new
+        dict with all base64 image values replaced by their OpenAI Files API
+        file_ids; non-image keys pass through untouched.
+        """
+
+        lane: str = 'uploader'
+        op: str = Field(default='upload', frozen=True)
+        payload: Any
