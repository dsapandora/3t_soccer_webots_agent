+"""tool_chase_ball — reactive 60Hz pursuit + auto-kick when ball is at feet."""
+
+from __future__ import annotations
+
+import json
+import os
+import time
+
+from rocketlib import IInstanceBase, tool_function
+
+from .IGlobal import IGlobal
+
+
+_DEBUG_LOG = "/tmp/rocketride_tool_chase_ball.log"
+
+
+def _audit(msg: str, payload: dict) -> None:
+    try:
+        with open(_DEBUG_LOG, "a", encoding="utf-8") as f:
+            f.write(json.dumps({
+                "t": time.strftime("%H:%M:%S"),
+                "pid": os.getpid(),
+                "msg": msg,
+                "payload": payload,
+            }) + "\n")
+    except OSError:
+        pass
+
+
+class IInstance(IInstanceBase):
+    IGlobal: IGlobal
+
+    @tool_function(
+        input_schema={
+            "type": "object",
+            "properties": {
+                "duration_ms": {
+                    "type": "integer",
+                    "minimum": 2000,
+                    "maximum": 15000,
+                    "default": 8000,
+                    "description": "How long the chase runs at most (ends early if ball is lost or kicked).",
+                },
+                "rationale": {
+                    "type": "string",
+                    "default": "",
+                    "description": "One short sentence explaining the choice.",
+                },
+            },
+        },
+        output_schema={
+            "type": "object",
+            "properties": {
+                "action": {"type": "string"},
+                "params": {"type": "object"},
+                "duration_ms": {"type": "integer"},
+                "rationale": {"type": "string"},
+            },
+        },
+        description=(
+            "Soccer robot complex skill CHASE_BALL: track the ball with the "
+            "head, walk toward it, and kick automatically when it reaches your "
+            "feet. Direction of the kick is the closer foot. Use when ball.visible."
+        ),
+    )
+    def execute(self, args):
+        _audit("invoked", {"args": args})
+        if not isinstance(args, dict):
+            _audit("error_bad_args", {"args": args})
+            raise ValueError("Tool input must be a JSON object (dict)")
+        duration_ms = int(args.get("duration_ms", 8000))
+        rationale = str(args.get("rationale", ""))
+        result = {
+            "action": "CHASE_BALL",
+            "params": {},
+            "duration_ms": duration_ms,
+            "rationale": rationale,
+        }
+        _audit("returning", result)
+        return result
